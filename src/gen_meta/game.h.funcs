#if defined(__clang__)
#pragma clang diagnostic push
#pragma clang diagnostic ignored "-Wbraced-scalar-init"
#endif
#if defined(m_debug)
#define assert_e_action(val) assert_e_action_(val)

static void assert_e_action_(int val)
{
	assert(val >= e_action_move_forward && val < e_action_count);
}
#else
#define assert_e_action(val)

#endif
#if defined(__clang__)
#pragma clang diagnostic pop
#endif
